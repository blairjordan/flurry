FROM node:20-alpine AS build
WORKDIR /app

COPY homepage/package.json homepage/package-lock.json ./
RUN npm install

COPY homepage ./
RUN npm run build

FROM node:20-alpine AS app
WORKDIR /app

ENV NODE_ENV=production

COPY --from=build /app ./

EXPOSE 3001
CMD ["sh", "-c", "PORT=3001 HOSTNAME=0.0.0.0 npm run start"]
