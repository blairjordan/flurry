    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "graphile-worker": "^0.16.6",
    "openai": "^4.58.1",
    "pg": "^8.9.0",
    "postgraphile": "^4.13.0",
    "postgraphile-plugin-connection-filter": "^2.3.0",
    "resend": "^4.1.1",
    "socket.io": "^4.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.3.0",
